[user]
    name = Manuel Gil
    email = manuel.gil@unity3d.com
[blame]
    # commits to skip on blame (look in the file for docs)
    ignoreRevsFile = .git-blame-ignore-revs
[core]
    editor = nvim
    excludesfile = $HOME/.gitignore_global
    # turn on filesystem watcher to avoid rescanning tree for status
	untrackedCache = true
	fsmonitor = true
[credential]
    helper = store
    helper = /usr/local/share/gcm-core/git-credential-manager
[init]
    defaultBranch = main
[pull]
    ff = true
    rebase = true
[fetch]
    prune = true
    pruneTags = true
    all = true
[feature]
    # optimizations to speed certain operations in monorepos
    manyFiles = true
[diff]
    tool = bc
    algorithm = histogram
[difftool]
    prompt = true
[merge]
    tool = bc
[mergetool "bc"]
    trustExitCode = true
[status]
    showUntrackedFiles = all
[column]
    ui = auto
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff-so-fancy]
    stripLeadingSymbols = false
[oh-my-zsh]
    hide-dirty = 1

#[lfs]
#    storage = /opt/lfs_storage

[alias]
    sc = "!f() { git rev-parse --verify $1 >/dev/null 2>&1 && git checkout $1 || git checkout -b $1; }; f"
    gc-full = !git -c core.longPaths=true gc --aggressive --prune=now && git lfs prune --verify-remote

  

 
